{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": true,
  "refresh": "15s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["fleetops", "linux", "fleet"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FleetOps — Overview",
  "uid": "fleetops-overview",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nodes Online",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#3fb950" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        { "refId": "A", "expr": "fleet_nodes_total{status=\"online\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Degraded",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#d29922" }, "unit": "short" },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "fleet_nodes_total{status=\"degraded\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Offline",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#f85149" }, "unit": "short" },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "fleet_nodes_total{status=\"offline\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Open Alerts",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "#3fb950", "value": null }, { "color": "#d29922", "value": 1 }, { "color": "#f85149", "value": 3 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum(fleet_alerts_open) without (severity)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Avg CPU",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "#3fb950", "value": null }, { "color": "#d29922", "value": 70 }, { "color": "#f85149", "value": 90 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "avg(fleet_cpu_percent)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Avg Memory",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "#3fb950", "value": null }, { "color": "#d29922", "value": 75 }, { "color": "#f85149", "value": 90 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "avg(fleet_memory_percent)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU % per Node",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "fleet_cpu_percent", "legendFormat": "{{node}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory % per Node",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "fleet_memory_percent", "legendFormat": "{{node}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Disk % per Node",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "fleet_disk_percent", "legendFormat": "{{node}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Load Average (1m) per Node",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "fleet_load1", "legendFormat": "{{node}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 11,
      "type": "state-timeline",
      "title": "Node Status Timeline",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80, "lineWidth": 0 },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "offline", "color": "#f85149" }, "1": { "text": "online", "color": "#3fb950" }, "2": { "text": "degraded", "color": "#d29922" }, "3": { "text": "pending", "color": "#58a6ff" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "#f85149", "value": null } ] }
        },
        "overrides": []
      },
      "options": { "mergeValues": true, "showValue": "auto", "alignValue": "center", "rowHeight": 0.9, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "expr": "fleet_node_up", "legendFormat": "{{node}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
